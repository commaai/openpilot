# Copy to /etc/default/openpilot-cm5-dashcam and edit for the installed camera.
# Prefer a stable /dev/v4l/by-id/... symlink instead of /dev/video0.
CAMERA=/dev/video0
ENCODER_PRESET=ultrafast
MAIN_BITRATE=5000000
MIN_FREE_GB=10
MIN_FREE_PERCENT=10
# Arbitration/data bitrates for Panda buses 0,1,2 in kbit/s. Set these for the
# target vehicle before recording; a wrong bitrate can silently miss traffic.
CAN_SPEEDS=500,500,500
CAN_DATA_SPEEDS=2000,2000,2000
# Comma-separated bus indexes for legacy non-ISO CAN-FD; normally empty.
CANFD_NON_ISO_BUSES=none
# Set to the wired/expected buses (for example 0 or 0,1). Leaving this as none
# cannot detect a valid-but-wrong bitrate on a bus that produces no frames.
REQUIRED_CAN_BUSES=none
CAN_STALE_TIMEOUT=5
WATCHDOG_STARTUP_TIMEOUT=30
WATCHDOG_STALE_TIMEOUT=5
# Set this when more than one USB Panda may be attached.
# DASHCAM_PANDA_SERIAL=abcdef123456
DASHCAM_PANDA_OUTAGE_TIMEOUT=30
