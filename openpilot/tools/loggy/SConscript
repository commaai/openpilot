import os
import subprocess

import bootstrap_icons
import imgui
from openpilot.common.basedir import BASEDIR

Import('env', 'arch', 'common', 'messaging', 'cereal')

loggy_env = env.Clone()
loggy_env["LIBPATH"] += [imgui.MESA_DIR]
loggy_env["CPPPATH"] += [imgui.INCLUDE_DIR]
loggy_env["CXXFLAGS"] += [
  "-DGLFW_INCLUDE_NONE",
  '-DLOGGY_REPO_ROOT=\'"%s"\'' % os.path.realpath(BASEDIR),
  '-DBOOTSTRAP_ICONS_TTF=\'"%s"\'' % bootstrap_icons.TTF_PATH,
]

libs = [
  common,
  messaging,
  cereal,
  "capnp",
  "kj",
  File(f"{imgui.LIB_DIR}/libimgui.a"),
  File(f"{imgui.LIB_DIR}/libglfw3.a"),
  "json11",
  "m",
  "pthread",
  "z",
  "bz2",
  "zstd",
]

if arch == "Darwin":
  loggy_env["FRAMEWORKS"] = ["OpenGL", "Cocoa", "IOKit", "CoreFoundation", "CoreVideo"]
else:
  libs += ["GL", "dl"]

def generate_event_extractors(target, source, env):
  subprocess.check_call([
    "python3",
    "openpilot/tools/loggy/backend/generate_event_extractors.py",
    os.path.realpath(BASEDIR),
    str(target[0]),
  ])
  return None

event_extractors = loggy_env.Command("backend/generated_event_extractors.h", [
    "backend/generate_event_extractors.py",
    loggy_env.Glob("#openpilot/cereal/*.capnp"),
    loggy_env.Glob("#openpilot/cereal/include/*.capnp"),
    "#opendbc_repo/opendbc/car/car.capnp",
    "#opendbc_repo/opendbc/car/include/c++.capnp",
  ],
  generate_event_extractors,
)

workspace_obj = loggy_env.Object("shell/workspace", "shell/workspace.cc")
theme_obj = loggy_env.Object("shell/theme", "shell/theme.cc")
transport_obj = loggy_env.Object("shell/transport", "shell/transport.cc")
settings_obj = loggy_env.Object("shell/settings", "shell/settings.cc")
session_obj = loggy_env.Object("backend/session", "backend/session.cc")
extract_obj = loggy_env.Object("backend/extract", "backend/extract.cc")
loggy_env.Depends(extract_obj, event_extractors)
route_obj = loggy_env.Object("backend/route", "backend/route.cc")
loggy_env.Depends(route_obj, event_extractors)
export_obj = loggy_env.Object("backend/export", "backend/export.cc")
replay_support_objs = [
  loggy_env.Object("backend/replay_logreader", "#openpilot/tools/replay/logreader.cc"),
  loggy_env.Object("backend/replay_filereader", "#openpilot/tools/replay/filereader.cc"),
  loggy_env.Object("backend/replay_py_downloader", "#openpilot/tools/replay/py_downloader.cc"),
  loggy_env.Object("backend/replay_util", "#openpilot/tools/replay/util.cc"),
]
dbc_objs = [
  loggy_env.Object("backend/dbc/dbc", "backend/dbc/dbc.cc"),
  loggy_env.Object("backend/dbc/dbcfile", "backend/dbc/dbcfile.cc"),
  loggy_env.Object("backend/dbc/dbcmanager", "backend/dbc/dbcmanager.cc"),
]
store_scheduler_objs = [
  loggy_env.Object("backend/store", "backend/store.cc"),
  loggy_env.Object("backend/ingest", "backend/ingest.cc"),
]
logs_obj = loggy_env.Object("panes/logs", "panes/logs.cc")
historylog_obj = loggy_env.Object("panes/historylog", "panes/historylog.cc")
browser_obj = loggy_env.Object("panes/browser", "panes/browser.cc")
dbc_pane_obj = loggy_env.Object("panes/dbc", "panes/dbc.cc")
map_obj = loggy_env.Object("panes/map", "panes/map.cc")
signal_obj = loggy_env.Object("panes/signal", "panes/signal.cc")
pane_objs = [
  loggy_env.Object("panes/plot", "panes/plot.cc"),
  loggy_env.Object("panes/messages", "panes/messages.cc"),
  loggy_env.Object("panes/binary", "panes/binary.cc"),
  browser_obj,
  dbc_pane_obj,
  map_obj,
  signal_obj,
  historylog_obj,
  logs_obj,
]

loggy_env.Program("_loggy", [
  "main.cc",
  "shell/runtime.cc",
  theme_obj,
  workspace_obj,
  transport_obj,
  session_obj,
  route_obj,
  extract_obj,
] + store_scheduler_objs + [settings_obj, export_obj] + pane_objs + dbc_objs + replay_support_objs, LIBS=libs)

loggy_env.Program("tests/workspace_smoke", [
  "tests/workspace_smoke.cc",
  workspace_obj,
  theme_obj,
  transport_obj,
  session_obj,
  route_obj,
  extract_obj,
] + store_scheduler_objs + [settings_obj, export_obj] + pane_objs + dbc_objs + replay_support_objs, LIBS=libs)

loggy_env.Program("tests/dbc_parser", [
  "tests/dbc_test_runner.cc",
  "tests/dbc_parser_test.cc",
] + dbc_objs, LIBS=libs)

loggy_env.Program("tests/transport_smoke", [
  "tests/transport_smoke.cc",
  transport_obj,
], LIBS=libs)

loggy_env.Program("tests/settings_smoke", [
  "tests/dbc_test_runner.cc",
  "tests/settings_smoke.cc",
  settings_obj,
], LIBS=libs)

loggy_env.Program("tests/store_scheduler", [
  "tests/dbc_test_runner.cc",
  "tests/store_scheduler_test.cc",
  transport_obj,
] + store_scheduler_objs, LIBS=libs)

loggy_env.Program("tests/export_smoke", [
  "tests/dbc_test_runner.cc",
  "tests/export_smoke.cc",
  export_obj,
  transport_obj,
] + store_scheduler_objs + dbc_objs, LIBS=libs)

loggy_env.Program("tests/panes_smoke", [
  "tests/dbc_test_runner.cc",
  "tests/panes_smoke.cc",
  browser_obj,
  map_obj,
  logs_obj,
  theme_obj,
  transport_obj,
] + store_scheduler_objs + dbc_objs, LIBS=libs)

loggy_env.Program("tests/extract_smoke", [
  "tests/dbc_test_runner.cc",
  "tests/extract_smoke.cc",
  extract_obj,
  transport_obj,
] + store_scheduler_objs, LIBS=libs)

loggy_env.Program("tests/route_ingest_smoke", [
  "tests/route_ingest_smoke.cc",
  route_obj,
  extract_obj,
  transport_obj,
] + store_scheduler_objs + replay_support_objs, LIBS=libs)
