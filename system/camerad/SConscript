Import('env', 'arch', 'messaging', 'common', 'visionipc')

libs = [common, messaging, visionipc]
common_srcs = ['cameras/camera_common.cc', 'cameras/cdm.cc', 'sensors/ox03c10.cc', 'sensors/os04c10.cc']

if arch != "Darwin":
  mainline = GetOption("mainline") or env.get("MAINLINE_KERNEL", False)
  if mainline:
    camera_obj = env.Object(['cameras/camera_mainline.cc'] + common_srcs)
  else:
    camera_obj = env.Object(['cameras/camera_qcom2.cc', 'cameras/spectra.cc'] + common_srcs)
  env.Program('camerad', ['main.cc', camera_obj], LIBS=libs)

if GetOption("extras") and arch == "x86_64":
  camera_obj = env.Object(['cameras/camera_qcom2.cc', 'cameras/spectra.cc'] + common_srcs)
  env.Program('test/test_ae_gray', ['test/test_ae_gray.cc', camera_obj], LIBS=libs)
